# Copy this file to .env and fill in your own values. The pipeline will
# auto-load .env via pipeline/config.py.
#
# All LLM calls in this repo speak the OpenAI chat-completions protocol.
# Two ways to satisfy that contract — pick one:
#
# 1) Local server on 2× A100 (see llm_serving/serve_vllm.sh):
#       LLM_BASE_URL=http://localhost:8000/v1
#       LLM_API_KEY=local
#       LLM_MODEL=gemma3:27b
#
# 2) Rented Vast.ai 4× A100 instance (or any other host) exposing the same
#    OpenAI-compatible /v1 endpoint:
#       LLM_BASE_URL=http://<your-vast-host>:<port>/v1
#       LLM_API_KEY=<your key>
#       LLM_MODEL=gemma3:27b

LLM_BASE_URL=http://localhost:8000/v1
LLM_API_KEY=local
LLM_MODEL=gemma3:27b

# Optional: pin the verifier model used by the perturbation / agreement evals
# to the same locally-served model (otherwise it falls back to LLM_MODEL).
EVAL_VERIFIER_MODEL=gemma3:27b

# OpenAI / Anthropic keys are only used by the legacy bench300/bench600
# extraction harnesses and are NOT required for either reproduction notebook.
# Leave commented unless you specifically want them.
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
